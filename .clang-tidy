#
# clang-tidy configuration for AMA Cryptography (audit Issue 9
# close-out — gate is FAIL-CLOSED).
#
# The checks below are scoped to high-signal categories that are useful
# for cryptographic C code without producing a wall of style noise that
# obscures genuine findings.  The exclusions in `Checks:` below opt out
# of style-only checks that the project's own conventions (CSRC_STANDARDS.md)
# already cover; the project's clang-format config is the source of truth
# for those.
#
# CURRENT POSTURE (2026-05): FAIL-CLOSED.  Every enabled check is
# promoted to error via `WarningsAsErrors: '*'` below; the corresponding
# CI job (`.github/workflows/static-analysis.yml::clang-tidy`) no
# longer carries `continue-on-error: true` or an `exit 0` trailer.  A
# new finding fails the workflow.  Four checks that the audit
# Issue 9 close-out walk surfaced as genuinely incompatible with the
# project's cryptographic-C style or as known false-positive sources
# are explicitly dropped from the `Checks:` list with a one-line
# rationale below, NOT silenced per-site (the user-facing contract is
# "the listed categories are fail-closed" — if a category genuinely
# doesn't belong on the list, drop it explicitly, do not pretend it's
# enforced).
#
# Inline `// NOLINT(check-name)` comments are subject to INVARIANT-13
# (justification + tracking ID required) — same hygiene policy as
# ruff `# noqa` / bandit `# nosec` markers.  As of the audit Issue 9
# close-out the codebase carries exactly one NOLINT (in
# `src/c/ed25519_donna_shim.c::ama_ed25519_point_from_scalar`,
# suppressing a clang-analyzer false positive on vendor donna code).
# Adding a new NOLINT to silence a category-wide noise pattern is the
# wrong answer; either fix the code, or drop the category from
# `Checks:` here with a rationale.

Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  concurrency-*,
  misc-misplaced-const,
  misc-redundant-expression,
  misc-static-assert,
  misc-unused-parameters,
  performance-*,
  portability-*,
  readability-misleading-indentation,
  readability-misplaced-array-index,
  readability-non-const-parameter,
  readability-redundant-control-flow,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-implicit-widening-of-multiplication-result,
  -cert-err33-c,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -performance-no-int-to-ptr,
  -readability-magic-numbers,
  -bugprone-reserved-identifier,
  -cert-dcl37-c,
  -cert-dcl51-cpp,
  -readability-redundant-declaration,
  -clang-analyzer-deadcode.DeadStores,
  -concurrency-mt-unsafe,
  -clang-analyzer-core.UndefinedBinaryOperatorResult

# Four checks dropped from `Checks:` above with rationale (audit
# Issue 9 close-out walk — surfaced ~50 false-positive-class findings
# that no inline NOLINT could honestly justify):
#
#   readability-redundant-declaration  — ~26 sites where the same TU
#     re-declares an `extern` function whose declaration is already in
#     the public header included earlier in the file.  The repeat-decl
#     improves locality of intent (callers see the prototype next to
#     the call) and is a recognised project convention (CSRC_STANDARDS).
#     Cleaning these up would require deleting every co-located
#     forward-decl, hurting locality with no behaviour change.
#
#   clang-analyzer-deadcode.DeadStores — was firing on the per-word
#     defensive scrubs (`sX = 0;`) inside `src/c/ama_ed25519.c`'s
#     scalar-reduction.  Those have been REWRITTEN in this commit to
#     `ama_secure_memzero(&sX, sizeof(sX))` so the scrub is now
#     elision-resistant (INVARIANT-6 strengthening).  The check is
#     dropped because the SAME kernel of dead-but-deliberate stores
#     can re-appear in similar lattice-arithmetic reduction code, and
#     converting EVERY arithmetic-only `int64_t = 0` to
#     `ama_secure_memzero` would be both performance-pessimal and
#     algorithmically misleading.
#
#   concurrency-mt-unsafe — fires on `getenv()` calls inside
#     `src/c/dispatch/ama_dispatch.c::dispatch_init_internal()`.  The
#     dispatcher's runtime contract (INVARIANT-15) is that
#     `dispatch_init_internal` runs exactly once per process under
#     `pthread_once` / `InitOnceExecuteOnce`, so the `getenv` calls
#     execute in a single-threaded context by construction.  The
#     check doesn't understand once-init gating and would force a
#     no-op refactor (e.g., a project-side `safe_getenv` wrapper)
#     that adds zero safety.
#
#   clang-analyzer-core.UndefinedBinaryOperatorResult — fires once,
#     from `src/c/ed25519_donna_shim.c::ama_ed25519_point_from_scalar`
#     calling into `src/c/vendor/ed25519-donna/curve25519-donna-64bit.h:85`.
#     The interprocedural pass loses track of the vendor donna macro
#     that initialises the field-element argument and flags the read
#     as "garbage".  The kernel is KAT-verified and vendor code gets
#     no project-side modifications.  Dropping ONLY this one check
#     keeps the rest of `clang-analyzer-*` (the security-bearing
#     family) enforced.  Note: a NOLINT on the calling line in
#     ed25519_donna_shim.c is preserved for the older clang-tidy
#     releases that report the warning at the call site rather than
#     at the vendor source location.

# WarningsAsErrors flips every enabled check above to an ERROR.  See
# the header for the audit Issue 9 close-out rationale.  PRs that
# touch .clang-tidy must keep this fail-closed posture; a backslide
# to `WarningsAsErrors: ''` reintroduces the very advisory-gate
# pattern this close-out removes.
WarningsAsErrors: '*'

# Header filter:
#   We only check our own headers (src/c/, include/).  Vendored sources
#   under src/c/vendor/ and third-party headers under /usr/include are
#   excluded — clang-tidy would otherwise drown the output in third-
#   party-noise.
HeaderFilterRegex: '^(.*/)?(src/c|include)/(?!vendor/).*\.h$'

# Format style — match the project's clang-format config.
FormatStyle: file

# Per-check configuration
CheckOptions:
  - key: readability-non-const-parameter.IgnoreMacros
    value: 'true'
  - key: bugprone-suspicious-string-compare.WarnOnImplicitComparison
    value: 'true'
  - key: bugprone-suspicious-string-compare.WarnOnLogicalNotComparison
    value: 'true'

# Style options scoped to the C dialect we target.
User: 'ama-cryptography'
