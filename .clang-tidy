#
# clang-tidy configuration for AMA Cryptography (audit Issue 9, deferral
# close-out 2026-05).
#
# The checks below are scoped to high-signal categories that are useful
# for cryptographic C code without producing a wall of style noise that
# obscures genuine findings.  The exclusions in `Checks:` below opt out
# of style-only checks that the project's own conventions
# (CSRC_STANDARDS.md) already cover; the project's clang-format config
# is the source of truth for those.
#
# POSTURE: FAIL-CLOSED.  `WarningsAsErrors: '*'` below promotes every
# enabled finding to an error.  The CI job
# (`.github/workflows/static-analysis.yml::clang-tidy`) no longer
# carries `continue-on-error: true`, so a fresh finding fails the job.
# The enabled-and-excluded list represents the audit Issue 9 deferral
# close-out walk: every excluded sub-check carries an inline rationale
# explaining either (a) genuine incompatibility with the project's
# cryptographic-C style, or (b) project-pattern noise that is
# specifically documented in CHANGELOG.md.
#
# Inline `// NOLINT(check-name, justification)` comments are subject
# to INVARIANT-13 (justification + tracking ID required) — same hygiene
# policy as ruff `# noqa` / bandit `# nosec` markers.  After the
# deferral close-out walk this codebase carries exactly three NOLINTs,
# all in `src/c/dispatch/ama_dispatch.c` and all referencing the
# INVARIANT-15-DISPATCH tracking ID (centralized in two static helper
# wrappers: dispatch_getenv() and dispatch_abort_unsupported()).

Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  concurrency-*,
  misc-misplaced-const,
  misc-redundant-expression,
  misc-static-assert,
  misc-unused-parameters,
  performance-*,
  portability-*,
  readability-misleading-indentation,
  readability-misplaced-array-index,
  readability-non-const-parameter,
  readability-redundant-control-flow,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-implicit-widening-of-multiplication-result,
  -bugprone-macro-parentheses,
  -bugprone-reserved-identifier,
  -cert-dcl37-c,
  -cert-dcl51-cpp,
  -cert-err33-c,
  -clang-analyzer-core.UndefinedBinaryOperatorResult,
  -clang-analyzer-deadcode.DeadStores,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -performance-no-int-to-ptr,
  -readability-magic-numbers,
  -readability-redundant-declaration

# Rationale for the excluded sub-checks (audit Issue 9 deferral close-out
# walk — 2026-05).  Order matches the negated-checks block above:
#
#   bugprone-easily-swappable-parameters  — fires on every multi-arg
#       cryptographic primitive (key + nonce, plaintext + ciphertext);
#       structural noise that does not catch real bugs in this codebase.
#   bugprone-narrowing-conversions        — high false-positive rate on
#       int-arithmetic-into-uint8 byte assembly used pervasively across
#       the curve / lattice serializers; downstream casts are explicit
#       and reviewed.
#   bugprone-implicit-widening-of-multiplication-result — same as above
#       for size-times-count multiplication; the project's policy is
#       to use `(uint64_t)a * b` form where it actually matters.
#   bugprone-macro-parentheses            — defensive crypto macros
#       (FIPS 202 / FIPS 203 / FIPS 204 rotation, mask, mix primitives)
#       are written with carefully-bounded paren coverage; clang-tidy's
#       paren expectation pattern produces 42 findings on macros that
#       are correctness-reviewed by the algorithm authors and not
#       changeable without algorithmic rewrite.
#   bugprone-reserved-identifier          — clashes with C11 _Alignas,
#       _Static_assert, and the project's _internal helper convention.
#   cert-dcl37-c, cert-dcl51-cpp          — same reserved-identifier
#       category as above (different rule IDs, same noise pattern).
#   cert-err33-c                          — every memcpy/memset/strncpy
#       return value would have to be checked; the project uses these
#       in safe contexts where the size argument is the source of truth.
#   clang-analyzer-core.UndefinedBinaryOperatorResult — fires only on
#       inlined vendor code in src/c/vendor/ed25519-donna/ which we
#       do not modify; HeaderFilterRegex below excludes header-level
#       diagnostics but the analyzer still reports findings in headers
#       when analyzing the includer TU.
#   clang-analyzer-deadcode.DeadStores    — the SUPERCOP Ed25519 sc_reduce
#       unrolled loop in src/c/ama_ed25519.c clears each high limb
#       (s23 = 0; s22 = 0; ...) after distributing it into lower limbs;
#       the writes ARE dead from a use-after-store standpoint but are
#       part of the SUPERCOP reference idiom that documents semantic
#       transitions in the algorithm.  Removing them would diverge
#       from the upstream reference without changing observable
#       behaviour.
#   clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling
#                                          — the project uses memcpy +
#       bounded sizes; this check would flag every primitive.
#   performance-no-int-to-ptr             — the project does not do
#       integer-to-pointer in production code; the few SVE2 and AVX2
#       intrinsic wrappers that do are explicit and reviewed.
#   readability-magic-numbers             — cryptographic algorithms
#       are defined in terms of magic numbers (FIPS-mandated constants,
#       NIST parameter sets, Keccak iota constants, etc.) which the
#       check cannot meaningfully whitelist.
#   readability-redundant-declaration     — the project's internal
#       headers (e.g., src/c/avx2/ama_avx2_internal.h) re-declare
#       symbols that are also declared in include/ama_dispatch.h, by
#       design — the internal header carries the AVX2-only symbol
#       cluster while the public header carries the dispatch table
#       only.  See CHANGELOG #322 entry.

# WarningsAsErrors: every check that survived the exclusion list above
# is a fail-closed gate.  This is the audit Issue 9 deferral close-out:
# the codebase has been walked clean of every enabled-category finding,
# so a future regression in any of these categories fails the
# `.github/workflows/static-analysis.yml::clang-tidy` job.
WarningsAsErrors: '*'

# Header filter:
#   We only check our own headers (src/c/, include/).  Vendored sources
#   under src/c/vendor/ and third-party headers under /usr/include are
#   excluded — clang-tidy would otherwise drown the output in third-
#   party-noise.
HeaderFilterRegex: '^(.*/)?(src/c|include)/(?!vendor/).*\.h$'

# Format style — match the project's clang-format config.
FormatStyle: file

# Per-check configuration
CheckOptions:
  - key: readability-non-const-parameter.IgnoreMacros
    value: 'true'
  - key: bugprone-suspicious-string-compare.WarnOnImplicitComparison
    value: 'true'
  - key: bugprone-suspicious-string-compare.WarnOnLogicalNotComparison
    value: 'true'

# Style options scoped to the C dialect we target.
User: 'ama-cryptography'
