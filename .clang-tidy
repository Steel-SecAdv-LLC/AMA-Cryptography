#
# clang-tidy configuration for AMA Cryptography (audit Issue 9).
#
# The checks below are scoped to high-signal categories that are useful
# for cryptographic C code without producing a wall of style noise that
# obscures genuine findings.  The exclusions in `Checks:` below opt out
# of style-only checks that the project's own conventions (CSRC_STANDARDS.md)
# already cover; the project's clang-format config is the source of truth
# for those.
#
# CURRENT POSTURE (2026-05): ADVISORY.  This config enables the high-
# signal categories above so developers and CI see the findings, but
# `WarningsAsErrors` is intentionally NOT set to `*`.  The codebase
# carries ~250 pre-existing findings — mostly
# `bugprone-implicit-widening-of-multiplication-result` (legitimate
# size-promotion noise) and `readability-redundant-declaration` (extern
# decls that mirror public-header decls inside the same TU).  These
# are not regressions introduced by audit Issue 9; promoting the gate
# to fail-closed today would block every subsequent PR until a
# dedicated cleanup pass lands.
#
# ROADMAP TO FAIL-CLOSED:
#   1. Land cleanup PRs that drive the finding count to zero
#      category-by-category (start with `cert-*` and `clang-analyzer-*`,
#      which are the truly security-bearing checks).
#   2. Set `WarningsAsErrors: '<cleaned-category>'` for each cleaned
#      category as it lands.
#   3. Promote the CI job (`.github/workflows/static-analysis.yml::clang-tidy`)
#      from advisory (`continue-on-error: true`) to fail-closed.
#
# Inline `// NOLINT(check-name, justification)` comments are subject
# to INVARIANT-13 (justification + tracking ID required) — same hygiene
# policy as ruff `# noqa` / bandit `# nosec` markers.

Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  concurrency-*,
  misc-misplaced-const,
  misc-redundant-expression,
  misc-static-assert,
  misc-unused-parameters,
  performance-*,
  portability-*,
  readability-misleading-indentation,
  readability-misplaced-array-index,
  readability-non-const-parameter,
  readability-redundant-control-flow,
  readability-redundant-declaration,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-implicit-widening-of-multiplication-result,
  -cert-err33-c,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -performance-no-int-to-ptr,
  -readability-magic-numbers,
  -bugprone-reserved-identifier,
  -cert-dcl37-c,
  -cert-dcl51-cpp

# WarningsAsErrors is unset (== no checks promoted to errors).  See
# the ROADMAP above for the phased promotion plan; PRs that touch
# .clang-tidy must keep the roadmap accurate.
WarningsAsErrors: ''

# Header filter:
#   We only check our own headers (src/c/, include/).  Vendored sources
#   under src/c/vendor/ and third-party headers under /usr/include are
#   excluded — clang-tidy would otherwise drown the output in third-
#   party-noise.
HeaderFilterRegex: '^(.*/)?(src/c|include)/(?!vendor/).*\.h$'

# Format style — match the project's clang-format config.
FormatStyle: file

# Per-check configuration
CheckOptions:
  - key: readability-non-const-parameter.IgnoreMacros
    value: 'true'
  - key: bugprone-suspicious-string-compare.WarnOnImplicitComparison
    value: 'true'
  - key: bugprone-suspicious-string-compare.WarnOnLogicalNotComparison
    value: 'true'

# Style options scoped to the C dialect we target.
User: 'ama-cryptography'
