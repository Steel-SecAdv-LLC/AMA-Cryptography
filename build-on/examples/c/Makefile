	cd /home/runner/work/AMA-Cryptography/AMA-Cryptography/build-on && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
