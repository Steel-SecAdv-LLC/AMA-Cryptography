{
  "metadata": {
    "version": "2.1.0",
    "created": "2026-03-19T00:00:00Z",
    "description": "AMA Cryptography performance baseline for regression detection",
    "system": "GitHub Actions shared runner, Linux x86-64, Python 3.11",
    "notes": "v2.1.0 baseline recalibrated for CI hardware. Ed25519 baselines set to 65% of CI-measured performance (16303/13119/5256 ops/sec) to provide 35% regression headroom matching tolerance_percent. SHA3/HMAC/HKDF baselines unchanged (pass with large margin). Ed25519 uses radix 2^51 field arithmetic (fe51.h). SHA3-256 uses fully unrolled Keccak-f[1600]. PQC benchmarks use native C library."
  },
  "thresholds": {
    "regression_threshold_percent": 10,
    "minimum_iterations": 50,
    "warmup_iterations": 5
  },
  "benchmarks": {
    "ama_sha3_256_hash": {
      "description": "AMA native C SHA3-256 hashing of 1KB data (FIPS 202, ctypes)",
      "metric": "operations_per_second",
      "baseline_value": 15000,
      "unit": "ops/sec",
      "tolerance_percent": 30,
      "tier": "microbenchmark"
    },
    "hmac_sha3_256": {
      "description": "HMAC-SHA3-256 authentication (native C via ctypes)",
      "metric": "operations_per_second",
      "baseline_value": 12000,
      "unit": "ops/sec",
      "tolerance_percent": 40,
      "tier": "microbenchmark"
    },
    "ed25519_keygen": {
      "description": "Ed25519 key pair generation (native C)",
      "metric": "operations_per_second",
      "baseline_value": 10600,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "ed25519_sign": {
      "description": "Ed25519 signature generation (native C, expanded key)",
      "metric": "operations_per_second",
      "baseline_value": 8527,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "ed25519_verify": {
      "description": "Ed25519 signature verification (native C)",
      "metric": "operations_per_second",
      "baseline_value": 3416,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "hkdf_derive": {
      "description": "HKDF-SHA3-256 key derivation (3 keys)",
      "metric": "operations_per_second",
      "baseline_value": 6500,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "full_package_create": {
      "description": "Complete crypto package creation (with PQC)",
      "metric": "operations_per_second",
      "baseline_value": 280,
      "unit": "ops/sec",
      "tolerance_percent": 50,
      "tier": "complex_operation"
    },
    "full_package_verify": {
      "description": "Complete crypto package verification (with PQC)",
      "metric": "operations_per_second",
      "baseline_value": 380,
      "unit": "ops/sec",
      "tolerance_percent": 50,
      "tier": "complex_operation"
    }
  },
  "pqc_benchmarks": {
    "dilithium_keygen": {
      "description": "ML-DSA-65 (Dilithium) key pair generation (native C)",
      "metric": "operations_per_second",
      "baseline_value": 500,
      "unit": "ops/sec",
      "tolerance_percent": 40,
      "optional": true
    },
    "dilithium_sign": {
      "description": "ML-DSA-65 (Dilithium) signature generation (native C)",
      "metric": "operations_per_second",
      "baseline_value": 140,
      "unit": "ops/sec",
      "tolerance_percent": 40,
      "optional": true
    },
    "dilithium_verify": {
      "description": "ML-DSA-65 (Dilithium) signature verification (native C)",
      "metric": "operations_per_second",
      "baseline_value": 530,
      "unit": "ops/sec",
      "tolerance_percent": 40,
      "optional": true
    }
  }
}
