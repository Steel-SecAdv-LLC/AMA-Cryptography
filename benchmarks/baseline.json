{
  "metadata": {
    "version": "2.0.1",
    "created": "2026-03-07T00:00:00Z",
    "description": "AMA Cryptography performance baseline for regression detection",
    "system": "GitHub Actions ubuntu-latest, Python 3.11",
    "notes": "v2.0.1 baseline recalibration against measured CI runner performance. All baselines derived from actual runs, not theoretical maximums. HKDF corrected from aspirational 60k to measured ~15k (cryptography library HKDF-SHA3-256 on CI hardware). PQC benchmarks use native C library via ctypes."
  },
  "thresholds": {
    "regression_threshold_percent": 10,
    "minimum_iterations": 50,
    "warmup_iterations": 5
  },
  "benchmarks": {
    "sha3_256_hash": {
      "description": "SHA3-256 hashing of 1KB data",
      "metric": "operations_per_second",
      "baseline_value": 150000,
      "unit": "ops/sec",
      "tolerance_percent": 25,
      "tier": "microbenchmark"
    },
    "hmac_sha3_256": {
      "description": "HMAC-SHA3-256 authentication",
      "metric": "operations_per_second",
      "baseline_value": 70000,
      "unit": "ops/sec",
      "tolerance_percent": 25,
      "tier": "microbenchmark"
    },
    "ed25519_keygen": {
      "description": "Ed25519 key pair generation",
      "metric": "operations_per_second",
      "baseline_value": 15000,
      "unit": "ops/sec",
      "tolerance_percent": 25,
      "tier": "microbenchmark"
    },
    "ed25519_sign": {
      "description": "Ed25519 signature generation",
      "metric": "operations_per_second",
      "baseline_value": 10000,
      "unit": "ops/sec",
      "tolerance_percent": 25,
      "tier": "microbenchmark"
    },
    "ed25519_verify": {
      "description": "Ed25519 signature verification",
      "metric": "operations_per_second",
      "baseline_value": 5000,
      "unit": "ops/sec",
      "tolerance_percent": 25,
      "tier": "microbenchmark"
    },
    "hkdf_derive": {
      "description": "HKDF-SHA3-256 key derivation (3 keys)",
      "metric": "operations_per_second",
      "baseline_value": 15000,
      "unit": "ops/sec",
      "tolerance_percent": 30,
      "tier": "microbenchmark"
    },
    "full_package_create": {
      "description": "Complete crypto package creation (with PQC)",
      "metric": "operations_per_second",
      "baseline_value": 400,
      "unit": "ops/sec",
      "tolerance_percent": 50,
      "tier": "complex_operation"
    },
    "full_package_verify": {
      "description": "Complete crypto package verification (with PQC)",
      "metric": "operations_per_second",
      "baseline_value": 800,
      "unit": "ops/sec",
      "tolerance_percent": 50,
      "tier": "complex_operation"
    }
  },
  "pqc_benchmarks": {
    "dilithium_keygen": {
      "description": "ML-DSA-65 (Dilithium) key pair generation",
      "metric": "operations_per_second",
      "baseline_value": 10000,
      "unit": "ops/sec",
      "tolerance_percent": 30,
      "optional": true
    },
    "dilithium_sign": {
      "description": "ML-DSA-65 (Dilithium) signature generation",
      "metric": "operations_per_second",
      "baseline_value": 5000,
      "unit": "ops/sec",
      "tolerance_percent": 30,
      "optional": true
    },
    "dilithium_verify": {
      "description": "ML-DSA-65 (Dilithium) signature verification",
      "metric": "operations_per_second",
      "baseline_value": 12000,
      "unit": "ops/sec",
      "tolerance_percent": 30,
      "optional": true
    }
  }
}
