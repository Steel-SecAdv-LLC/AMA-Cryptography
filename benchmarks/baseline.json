{
  "metadata": {
    "version": "2.1.0",
    "created": "2026-03-19T00:00:00Z",
    "description": "AMA Cryptography performance baseline for regression detection",
    "system": "Linux 6.18.5, Python 3.11.14, 4 cores",
    "notes": "v2.1.0 baseline recalibrated post Ed25519 expanded-key fix. All benchmarks use native C implementations via ctypes. Ed25519 sign baseline reflects expanded key storage (no re-expansion per sign). HMAC-SHA3-256 baseline reflects Cython-primary path calling native C ama_hmac_sha3_256 (INVARIANT-1 compliance). PQC benchmarks use native C library."
  },
  "thresholds": {
    "regression_threshold_percent": 10,
    "minimum_iterations": 50,
    "warmup_iterations": 5
  },
  "benchmarks": {
    "sha3_256_hash": {
      "description": "SHA3-256 hashing of 1KB data",
      "metric": "operations_per_second",
      "baseline_value": 270000,
      "unit": "ops/sec",
      "tolerance_percent": 30,
      "tier": "microbenchmark"
    },
    "hmac_sha3_256": {
      "description": "HMAC-SHA3-256 authentication (native C via ctypes)",
      "metric": "operations_per_second",
      "baseline_value": 30000,
      "unit": "ops/sec",
      "tolerance_percent": 40,
      "tier": "microbenchmark"
    },
    "ed25519_keygen": {
      "description": "Ed25519 key pair generation (native C)",
      "metric": "operations_per_second",
      "baseline_value": 2700,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "ed25519_sign": {
      "description": "Ed25519 signature generation (native C, expanded key)",
      "metric": "operations_per_second",
      "baseline_value": 2600,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "ed25519_verify": {
      "description": "Ed25519 signature verification (native C)",
      "metric": "operations_per_second",
      "baseline_value": 1400,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "hkdf_derive": {
      "description": "HKDF-SHA3-256 key derivation (3 keys)",
      "metric": "operations_per_second",
      "baseline_value": 6500,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "full_package_create": {
      "description": "Complete crypto package creation (with PQC)",
      "metric": "operations_per_second",
      "baseline_value": 280,
      "unit": "ops/sec",
      "tolerance_percent": 50,
      "tier": "complex_operation"
    },
    "full_package_verify": {
      "description": "Complete crypto package verification (with PQC)",
      "metric": "operations_per_second",
      "baseline_value": 380,
      "unit": "ops/sec",
      "tolerance_percent": 50,
      "tier": "complex_operation"
    }
  },
  "pqc_benchmarks": {
    "dilithium_keygen": {
      "description": "ML-DSA-65 (Dilithium) key pair generation (native C)",
      "metric": "operations_per_second",
      "baseline_value": 500,
      "unit": "ops/sec",
      "tolerance_percent": 40,
      "optional": true
    },
    "dilithium_sign": {
      "description": "ML-DSA-65 (Dilithium) signature generation (native C)",
      "metric": "operations_per_second",
      "baseline_value": 140,
      "unit": "ops/sec",
      "tolerance_percent": 40,
      "optional": true
    },
    "dilithium_verify": {
      "description": "ML-DSA-65 (Dilithium) signature verification (native C)",
      "metric": "operations_per_second",
      "baseline_value": 530,
      "unit": "ops/sec",
      "tolerance_percent": 40,
      "optional": true
    }
  }
}
