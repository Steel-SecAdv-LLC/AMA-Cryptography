{
  "metadata": {
    "version": "2.1.0",
    "created": "2026-03-10T00:00:00Z",
    "description": "AMA Cryptography performance baseline for regression detection",
    "system": "GitHub Actions ubuntu-latest, Python 3.11",
    "notes": "v2.1.0 baseline recalibration for native C backend (zero-dependency). All benchmarks now use native C implementations via ctypes instead of PyCA cryptography or liboqs. Ed25519 baselines reflect pure C implementation (no assembly). HKDF uses native SHA3-256 HKDF. PQC benchmarks use native C library via ctypes."
  },
  "thresholds": {
    "regression_threshold_percent": 10,
    "minimum_iterations": 50,
    "warmup_iterations": 5
  },
  "benchmarks": {
    "sha3_256_hash": {
      "description": "SHA3-256 hashing of 1KB data",
      "metric": "operations_per_second",
      "baseline_value": 112050,
      "unit": "ops/sec",
      "tolerance_percent": 25,
      "tier": "microbenchmark"
    },
    "hmac_sha3_256": {
      "description": "HMAC-SHA3-256 authentication",
      "metric": "operations_per_second",
      "baseline_value": 70000,
      "unit": "ops/sec",
      "tolerance_percent": 25,
      "tier": "microbenchmark"
    },
    "ed25519_keygen": {
      "description": "Ed25519 key pair generation (native C)",
      "metric": "operations_per_second",
      "baseline_value": 6000,
      "unit": "ops/sec",
      "tolerance_percent": 30,
      "tier": "microbenchmark"
    },
    "ed25519_sign": {
      "description": "Ed25519 signature generation (native C)",
      "metric": "operations_per_second",
      "baseline_value": 3000,
      "unit": "ops/sec",
      "tolerance_percent": 30,
      "tier": "microbenchmark"
    },
    "ed25519_verify": {
      "description": "Ed25519 signature verification (native C)",
      "metric": "operations_per_second",
      "baseline_value": 3000,
      "unit": "ops/sec",
      "tolerance_percent": 30,
      "tier": "microbenchmark"
    },
    "hkdf_derive": {
      "description": "HKDF-SHA3-256 key derivation (3 keys)",
      "metric": "operations_per_second",
      "baseline_value": 15000,
      "unit": "ops/sec",
      "tolerance_percent": 30,
      "tier": "microbenchmark"
    },
    "full_package_create": {
      "description": "Complete crypto package creation (with PQC)",
      "metric": "operations_per_second",
      "baseline_value": 120,
      "unit": "ops/sec",
      "tolerance_percent": 50,
      "tier": "complex_operation"
    },
    "full_package_verify": {
      "description": "Complete crypto package verification (with PQC)",
      "metric": "operations_per_second",
      "baseline_value": 800,
      "unit": "ops/sec",
      "tolerance_percent": 50,
      "tier": "complex_operation"
    }
  },
  "pqc_benchmarks": {
    "dilithium_keygen": {
      "description": "ML-DSA-65 (Dilithium) key pair generation (native C)",
