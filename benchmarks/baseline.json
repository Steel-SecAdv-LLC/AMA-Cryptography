{
  "metadata": {
    "version": "2.1.2",
    "created": "2026-04-08T00:00:00Z",
    "description": "AMA Cryptography performance baseline for regression detection",
    "system": "GitHub Actions shared runner, Linux x86-64, Python 3.11",
    "notes": "v2.1.2 post-PR #188 performance engineering overhaul. Baselines set to 65% of measured performance (35% regression headroom). Key improvements: AES-NI dispatch, Ed25519 comb tables + wNAF, batch verify, parallel hybrid verify, Cython hot-path bindings, redundant hash elimination, HKDF stack allocation, module-level imports."
  },
  "thresholds": {
    "regression_threshold_percent": 10,
    "minimum_iterations": 50,
    "warmup_iterations": 5
  },
  "benchmarks": {
    "ama_sha3_256_hash": {
      "description": "AMA native C SHA3-256 hashing of 1KB data (FIPS 202, ctypes)",
      "metric": "operations_per_second",
      "baseline_value": 808929,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "hmac_sha3_256": {
      "description": "HMAC-SHA3-256 authentication (native C via ctypes)",
      "metric": "operations_per_second",
      "baseline_value": 191931,
      "unit": "ops/sec",
      "tolerance_percent": 40,
      "tier": "microbenchmark"
    },
    "ed25519_keygen": {
      "description": "Ed25519 key pair generation (native C)",
      "metric": "operations_per_second",
      "baseline_value": 7834,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "ed25519_sign": {
      "description": "Ed25519 signature generation (native C, comb tables)",
      "metric": "operations_per_second",
      "baseline_value": 7780,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "ed25519_verify": {
      "description": "Ed25519 signature verification (native C, wNAF)",
      "metric": "operations_per_second",
      "baseline_value": 5511,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "hkdf_derive": {
      "description": "HKDF-SHA3-256 key derivation (3 keys, stack-allocated)",
      "metric": "operations_per_second",
      "baseline_value": 114308,
      "unit": "ops/sec",
      "tolerance_percent": 35,
      "tier": "microbenchmark"
    },
    "full_package_create": {
      "description": "Complete crypto package creation (with PQC, precomputed hash)",
      "metric": "operations_per_second",
      "baseline_value": 746,
      "unit": "ops/sec",
      "tolerance_percent": 50,
      "tier": "complex_operation"
    },
    "full_package_verify": {
      "description": "Complete crypto package verification (with PQC, parallel hybrid)",
      "metric": "operations_per_second",
      "baseline_value": 2176,
      "unit": "ops/sec",
      "tolerance_percent": 50,
      "tier": "complex_operation"
    }
  },
